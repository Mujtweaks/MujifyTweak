*.dev.cfg

# Owner-only tooling & docs — kept locally inside the project but buried in
# .build-cache/vendor/ and NEVER pushed to the public repo. The folder ignore
# plus the name patterns are belt-and-suspenders against any stray copy.
/.build-cache/
OWNER_DASHBOARD.md
analytics-worker/
