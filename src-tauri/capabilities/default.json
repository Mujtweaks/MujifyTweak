{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — Tauri v2 denies all window IPC by default; the frameless custom titlebar needs these explicitly.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://discord.gg/zg4WXbJ9uw" },
        { "url": "https://mujifytweaks.site.je" },
        { "url": "https://mujifytweaks.site.je/*" },
        { "url": "https://github.com/Mujtweaks/MujifyTweak/releases" },
        { "url": "https://github.com/Mujtweaks/MujifyTweak/releases/*" }
      ]
    }
  ]
}
